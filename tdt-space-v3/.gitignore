# ============================================================================
# TDT Space v3 - Git Ignore
# Wails v3 + Go + React + Bun
# ============================================================================

# ----------------------------------------------------------------------------
# Build & Output
# ----------------------------------------------------------------------------
# Build output directories
bin/
build/linux/appimage/build/
build/windows/nsis/MicrosoftEdgeWebview2Setup.exe

# Compiled binary
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out

# ----------------------------------------------------------------------------
# Frontend
# ----------------------------------------------------------------------------
# Dependencies
frontend/node_modules/
frontend/.pnpm-store/

# Build output
frontend/dist/

# Lock files (optional - keep one if you want deterministic installs)
# frontend/bun.lockb
# frontend/bun.lock

# Logs
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/pnpm-debug.log*

# Local env files
frontend/.env.local
frontend/.env.*.local

# ----------------------------------------------------------------------------
# Wails
# ----------------------------------------------------------------------------
# Wails generated files
wailsjs/
bindings/

# Task cache
.task/

